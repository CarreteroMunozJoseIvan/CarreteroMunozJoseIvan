results = []

for file in os.listdir(folder_path):
    if file.lower().endswith(".pdf"):
        pdf_path = os.path.join(folder_path, file)

        with pdfplumber.open(pdf_path) as pdf:
            for page_num, page in enumerate(pdf.pages, start=1):
                text = page.extract_text() or ""

                numero_documento = None
                expediente = None
                importe = None

                # Número de documento
                match_doc = re.search(r"Número de documento\s+(\d+)", text, re.IGNORECASE)
                if match_doc:
                    numero_documento = match_doc.group(1)

                # Expediente tipo VR 8547
                match_exp = re.search(r"\b(VR\s*\d+)\b", text, re.IGNORECASE)
                if match_exp:
                    expediente = match_exp.group(1).replace(" ", " ").upper()

                # Importe total
                match_importe = re.search(r"Total\s+([\d.,]+)", text, re.IGNORECASE)
                if match_importe:
                    importe = match_importe.group(1)

                if numero_documento or expediente or importe:
                    results.append({
                        "pdf_file": file,
                        "page": page_num,
                        "numero_documento": numero_documento,
                        "expediente": expediente,
                        "importe": importe
                    })

df = pd.DataFrame(results)
